{
  "version": "0.2.0",
  "configurations": [
    {
        "type": "java",
        "name": "LibManagement",
        "request": "launch",
        "mainClass": "bonifacio_bscs1a.libmanagement.LibManagement",
        "projectName": ""
    },
    {
        "type": "java",
        "name": "Launch LibManagement (LogIn)",
        "request": "launch",
        "mainClass": "bonifacio_bscs1a.libmanagement.LogIn",
        "projectName": "lmsJava",
        "cwd": "${workspaceFolder}",
        "env": {
            "LIBS_DIR": "${workspaceFolder}\\libs"
        },
        "vmArgs": "-Dfile.encoding=UTF-8"
    }
]
}
